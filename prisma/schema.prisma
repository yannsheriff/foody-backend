generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Score {
  tresLeger   @map("tres-leger")
  leger       @map("leger")
  normal      @map("normal")
  copieux     @map("copieux")
  tresCopieux @map("tres-copieux")
}

model User {
  id         Int             @id @default(autoincrement())
  email      String          @unique
  name       String
  password   String
  days       Days[]
  challenges UserChallenge[]

  @@map("users")
}

// Single-word lowercase values on purpose: Prisma identifier, DB string and
// wire string are identical, so no mapper is needed (unlike Score).
enum ChallengeStatus {
  active
  completed
  abandoned
}

// Effort level for the daily sport entry (replaces the old `sport` boolean).
// Single-word lowercase values: Prisma identifier = DB string = wire string,
// no mapper needed (like ChallengeStatus, unlike Score). NULL = not answered
// yet; `none` (repos) is a valid, deliberate answer worth 0 pt.
enum SportLevel {
  none
  normal
  intense
}

model UserChallenge {
  id           Int             @id @default(autoincrement())
  user_id      Int
  // Catalog id from challenges.constants.ts — ids are persisted, never rename.
  challenge_id String
  status       ChallengeStatus @default(active)
  started_at   DateTime        @default(now())
  completed_at DateTime?
  user         User            @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("user_challenges")
}

model Days {
  id              Int      @id @default(autoincrement())
  user_id         Int
  morning_score   Score?
  afternoon_score Score?
  evening_score   Score?
  snack           Float?
  // Legacy mirror kept in sync on write (true when sport_level is normal/intense)
  // for backward compatibility; sport_level is the source of truth for reads.
  sport           Boolean     @default(false)
  sport_level     SportLevel?
  sport_type      String?
  date            DateTime @default(now())
  // Set server-side the first time all 3 meals are filled; never overwritten.
  // NULL = pre-feature row, treated as on-time for the streak (grandfathered).
  meals_completed_at DateTime?
  user            User     @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("days")
}
