generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Score {
  tresLeger   @map("tres-leger")
  leger       @map("leger")
  normal      @map("normal")
  copieux     @map("copieux")
  tresCopieux @map("tres-copieux")
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  name     String
  password String
  days     Days[]

  @@map("users")
}

model Days {
  id              Int      @id @default(autoincrement())
  user_id         Int
  morning_score   Score?
  afternoon_score Score?
  evening_score   Score?
  snack           Float?
  sport           Boolean  @default(false)
  sport_type      String?
  date            DateTime @default(now())
  user            User     @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("days")
}
