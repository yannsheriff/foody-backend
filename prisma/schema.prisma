generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Score {
  tresLeger   @map("tres-leger")
  leger       @map("leger")
  normal      @map("normal")
  copieux     @map("copieux")
  tresCopieux @map("tres-copieux")
}

model User {
  id            Int                @id @default(autoincrement())
  email         String             @unique
  name          String
  password      String
  // Identifiant stable « Sign in with Apple » (claim sub) — null si compte email.
  apple_sub     String?            @unique
  // Intention d'onboarding ('lose'|'maintain'|'aware'|'snack') — synchronisée
  // par le client (POST /me/intention), pondère le tirage des défis (Phase 4).
  intention     String?
  days          Days[]
  challenges    UserChallenge[]
  weekly        WeeklyChallenge[]
  badges        UserBadge[]
  subscriptions PushSubscription[]
  coins         CoinTransaction[]
  freezes       FreezeConsumption[]

  @@map("users")
}

// One row per device/browser the user enabled reminders on (a user can have
// several). Stores the Web Push subscription returned by the browser; the
// daily reminder cron sends to every row whose owner hasn't completed today.
model PushSubscription {
  id         Int      @id @default(autoincrement())
  user_id    Int
  endpoint   String   @unique
  p256dh     String
  auth       String
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("push_subscriptions")
}

// Single-word lowercase values on purpose: Prisma identifier, DB string and
// wire string are identical, so no mapper is needed (unlike Score).
enum ChallengeStatus {
  active
  completed
  abandoned
}

// Effort level for the daily sport entry (replaces the old `sport` boolean).
// Single-word lowercase values: Prisma identifier = DB string = wire string,
// no mapper needed (like ChallengeStatus, unlike Score). NULL = not answered
// yet; `none` (repos) is a valid, deliberate answer worth 0 pt.
enum SportLevel {
  none
  normal
  intense
}

// Weekly challenge lifecycle. Single-word lowercase values on purpose: Prisma
// identifier = DB string = wire string, no mapper (like ChallengeStatus).
enum WeeklyChallengeStatus {
  active
  won
  lost
}

model UserChallenge {
  id           Int             @id @default(autoincrement())
  user_id      Int
  // Catalog id from challenges.constants.ts — ids are persisted, never rename.
  challenge_id String
  status       ChallengeStatus @default(active)
  started_at   DateTime        @default(now())
  completed_at DateTime?
  user         User            @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("user_challenges")
}

// The challenge a user picked for a given ISO week (one per user per week).
// Offers themselves are deterministic in code (not stored). `target` is frozen
// at selection (prorated when the user picks mid-week). Resolution is lazy at
// read time: an elapsed `active` row flips to `won`/`lost` and is then frozen.
model WeeklyChallenge {
  id            Int                   @id @default(autoincrement())
  user_id       Int
  iso_week      String // "2026-W30" (ISO-8601 week key)
  week_start    DateTime // Monday 00:00 UTC
  week_end      DateTime // Sunday 23:59:59.999 UTC
  // Catalog id from weekly-catalog.constants.ts — persisted, never rename.
  challenge_id  String
  flavor        String // 'accessible' | 'ambitious'
  target        Int // frozen at selection (prorated)
  status        WeeklyChallengeStatus @default(active)
  started_at    DateTime              @default(now())
  resolved_at   DateTime?
  reward_points Int? // snapshot (5 | 10) credited at resolution
  user          User                  @relation(fields: [user_id], references: [id])

  @@unique([user_id, iso_week]) // one chosen challenge per user per week
  @@index([user_id])
  @@map("weekly_challenges")
}

// Every unlocked badge — monthly (badge_id 'season-YYYY-MM') AND legacy
// achievements (badge_id = the spec id). Persisted because monthly points reset
// each month; achievements are backfilled lazily from day history on first read
// so no existing user loses a badge. Once written, a badge is frozen.
model UserBadge {
  id          Int      @id @default(autoincrement())
  user_id     Int
  badge_id    String
  unlocked_at DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id])

  @@unique([user_id, badge_id])
  @@index([user_id])
  @@map("user_badges")
}

model Days {
  id                 Int         @id @default(autoincrement())
  user_id            Int
  morning_score      Score?
  afternoon_score    Score?
  evening_score      Score?
  snack              Float?
  // Legacy mirror kept in sync on write (true when sport_level is normal/intense)
  // for backward compatibility; sport_level is the source of truth for reads.
  sport              Boolean     @default(false)
  sport_level        SportLevel?
  sport_type         String?
  date               DateTime    @default(now())
  // Set server-side the first time all 3 meals are filled; never overwritten.
  // NULL = pre-feature row, treated as on-time for the streak (grandfathered).
  meals_completed_at DateTime?
  // Économie Phase 3 — créneau du repas neutralisé par un cheat meal (choisi par
  // l'utilisateur : 'morning'|'afternoon'|'evening'). Server-only (posé par
  // l'endpoint boutique, jamais par un PATCH client). NULL = pas de cheat.
  // Scoré comme un 'normal' dans le calcul /10.
  cheat_slot         String?
  user               User        @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("days")
}

// Économie Phase 3 — grand livre des pièces (append-only). Solde = SUM(amount)
// (dérivé, jamais stocké). Les crédits d'« exploits » (défis/badge/paliers de
// flamme/bienvenue) sont idempotents via @@unique(user, reason, ref) et
// backfillés au 1er passage ; les achats (débits) sont créés à l'acte.
model CoinTransaction {
  id         Int      @id @default(autoincrement())
  user_id    Int
  amount     Int // signé : crédit > 0, débit (achat) < 0
  reason     String // 'challenge_won'|'monthly_badge'|'flame_milestone'|'welcome'|'buy_cheat_meal'|'buy_freeze'
  ref        String // idempotence des crédits : id défi / badge_id / 'milestone-<n>' / 'welcome'
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id])

  @@unique([user_id, reason, ref])
  @@index([user_id])
  @@map("coin_transactions")
}

// Économie Phase 3 — un gel de flamme consommé (auto, dernière défense après le
// catch-up) pour couvrir un jour manqué. Stock de gel = #achats − #consommations.
// `seen` pilote l'interstitiel / la notif « ta flamme a tenu ».
model FreezeConsumption {
  id          Int      @id @default(autoincrement())
  user_id     Int
  day         DateTime // le jour manqué couvert (UTC, tronqué au jour)
  consumed_at DateTime @default(now())
  seen        Boolean  @default(false)
  user        User     @relation(fields: [user_id], references: [id])

  @@unique([user_id, day])
  @@index([user_id])
  @@map("freeze_consumptions")
}
